# PRESSPILOT FRONTEND CONFIGURATION
# Copiez ce fichier en .env.local et remplissez vos valeurs

# Backend API URL
VITE_API_URL=http://localhost:3001

# Google Client ID for OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Ringover API Configuration
VITE_RINGOVER_API_KEY=your_ringover_api_key_here

# App Configuration
VITE_APP_NAME=PressPilot
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# Sentry (monitoring d'erreurs frontend)
VITE_SENTRY_DSN=https://your_sentry_dsn_here

# Analytics
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# Features toggles
VITE_ENABLE_PHONE_SYSTEM=true
VITE_ENABLE_CALL_RECORDING=false
VITE_ENABLE_ANALYTICS=false

# Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/*,audio/*,video/*,.pdf,.doc,.docx

# Cloudinary (upload images artistes)
VITE_CLOUDINARY_CLOUD_NAME=presspilot
VITE_CLOUDINARY_UPLOAD_PRESET=ml_default

# Facebook OAuth
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# WebSocket
VITE_WS_URL=ws://localhost:3001

# Debug
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
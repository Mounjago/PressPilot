# PRESSPILOT BACKEND CONFIGURATION - DEV
# Configuration de développement pour PressPilot

# Serveur
NODE_ENV=development
PORT=3002
FRONTEND_URL=http://localhost:5174

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/presspilot_dev

# JWT Configuration - IMPORTANTE: Changer en production
JWT_SECRET=presspilot_development_secret_key_2024_ultra_secure_change_in_production
JWT_EXPIRES_IN=7d

# Ringover API Configuration (optionnel pour développement)
RINGOVER_API_KEY=your_ringover_api_key_here
RINGOVER_BASE_URL=https://public-api.ringover.com/v2

# Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (pour notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dev@presspilot.com
SMTP_PASS=dev_password

# Mailgun Configuration (pour envoi emails campagnes)
MAILGUN_API_KEY=fake-key-for-development
MAILGUN_DOMAIN=sandbox-dev.mailgun.org
MAILGUN_FROM_EMAIL=noreply@presspilot.dev

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
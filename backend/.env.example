# PRESSPILOT BACKEND CONFIGURATION
# Copiez ce fichier en .env et remplissez vos valeurs

# Serveur
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=presspilot
DB_USER=presspilot_user
DB_PASSWORD=your_password_here

# Base de données MongoDB (alternative)
MONGODB_URI=mongodb://localhost:27017/presspilot

# JWT Configuration
JWT_SECRET=presspilot_secret_key_2024_change_this_in_production
JWT_EXPIRES_IN=7d

# Ringover API Configuration
RINGOVER_API_KEY=your_ringover_api_key_here
RINGOVER_BASE_URL=https://public-api.ringover.com/v2

# Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (pour notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Mailgun Configuration (pour envoi d'emails marketing)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_domain.mailgun.org
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
MAILGUN_WEBHOOK_SIGNING_KEY=your_webhook_signing_key
MAILGUN_BASE_URL=https://api.eu.mailgun.net

# Sentry (monitoring d'erreurs)
SENTRY_DSN=https://your_sentry_dsn_here

# Redis (cache et sessions)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
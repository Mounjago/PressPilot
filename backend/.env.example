# PRESSPILOT BACKEND CONFIGURATION
# Copiez ce fichier en .env et remplissez vos valeurs

# Serveur
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Base de donnees MongoDB
MONGODB_URI=mongodb://localhost:27017/presspilot

# JWT Configuration
JWT_SECRET=presspilot_secret_key_2024_change_this_in_production
JWT_EXPIRES_IN=7d

# Encryption (IMAP passwords) - min 32 caracteres
ENCRYPTION_KEY=change_this_to_a_random_32_char_string_minimum

# Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (SMTP pour envoi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Mailgun Configuration (envoi d'emails marketing)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_domain.mailgun.org
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
MAILGUN_WEBHOOK_SIGNING_KEY=your_webhook_signing_key
MAILGUN_BASE_URL=https://api.eu.mailgun.net

# Redis (queues Bull et cache)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# OpenAI (generation de communiques de presse via IA)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Sentry (monitoring d'erreurs - optionnel)
# SENTRY_DSN=https://your_sentry_dsn_here
